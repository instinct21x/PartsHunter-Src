# ──────────────────────────────────────────────
# PartsHunter Backend — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/partshunter

# JWT (auth)
JWT_SECRET=change_me_to_a_long_random_string

# ──────────────────────────────────────────────
# eBay Developer App
# Sign up at https://developer.ebay.com/
# ──────────────────────────────────────────────
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_DEV_ID=your_ebay_dev_id_here

# ──────────────────────────────────────────────
# Gumtree (placeholder — not yet implemented)
# When a public API or partner data feed is available, add credentials here.
# ──────────────────────────────────────────────
GUMTREE_API_KEY=

# ──────────────────────────────────────────────
# Facebook Marketplace (placeholder)
# Requires Meta Business API approval.
# ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
